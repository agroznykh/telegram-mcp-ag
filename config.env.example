# Конфигурация telegram-mcp-ag.
#
# Обычно этот файл создаёт install.sh в ~/telegram-mcp-ag/config.env —
# руками редактировать нужно, только если ставите сервер вручную или
# чините доступ. Права файла должны быть 600 (chmod 600 config.env):
# здесь лежит доступ к вашему Telegram-аккаунту.

# api_id и api_hash — с my.telegram.org/apps, раздел "API development tools".
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Строка сессии — появляется после входа в Telegram (QR-код или телефон+код).
# Одна строка сессии — одна машина: если её скопировать на вторую машину,
# Telegram завершит обе сессии ошибкой AUTH_KEY_DUPLICATED. Для второй
# машины нужен отдельный вход, а не копирование этого значения.
TELEGRAM_SESSION_STRING=

# read-only запрещает серверу отправлять сообщения и менять данные аккаунта.
# Не снимайте это ограничение без явной необходимости.
TELEGRAM_EXPOSED_TOOLS=read-only

# Имя, под которым сессия видна в Telegram -> Settings -> Devices.
TELEGRAM_DEVICE_MODEL=Telegram MCP AG
